# MADEWELL AI BOARDROOM v0.3.4
# 실제 키는 여기에만 넣고, 이 파일이나 .env를 채팅창에 업로드하지 마세요.

ANTHROPIC_API_KEY=여기에_Anthropic_Claude_API_Key
OPENAI_API_KEY=여기에_OpenAI_API_Key

# Gemini는 선택사항입니다. 기본은 꺼져 있고 GPT가 Gemini 역할을 안전 대체합니다.
GEMINI_API_KEY=

CLAUDE_MODEL=claude-sonnet-4-6
GPT_MODEL=gpt-5.5
GEMINI_MODEL=gemini-2.5-flash

# 중요: 0이면 실제 Gemini API 호출 안 함. API 키 만료/쿼터 오류 방지.
# 꼭 실제 Gemini를 쓰고 싶을 때만 1로 바꾸세요.
USE_GEMINI_API=0
GEMINI_STRICT=0
